{
  "name": "ai-llmgateway",
  "version": "0.1.3",
  "description": "TypeScript SDK for llm-gateway — the fast Rust LLM proxy. Compatible with OpenAI, Anthropic, and Gemini field conventions.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "gateway",
    "proxy",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
